# Botersson Configuration

# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=               # optional: restrict to a specific guild

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2           # or mistral, phi3, etc.
LLM_PERSONA_NAME=Botersson
LLM_PERSONA_STYLE=inspirada em Albert Camus: claro, humano, lúcido, reflexivo e direto
LLM_RESPONSE_LANGUAGE=português (pt-BR)

# ── Web GUI ──────────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_SECRET_KEY=change-me-to-a-random-secret

# ── Data paths ───────────────────────────────────────────────────────────────
DATA_DIR=./data
EXCEL_FILENAME=research_data.xlsx

# ── Search engines ────────────────────────────────────────────────────────────
# DuckDuckGo is used by default (no API key needed)
# Optionally set a SerpAPI or Bing key for richer results
# SERPAPI_KEY=
# BING_SEARCH_KEY=
